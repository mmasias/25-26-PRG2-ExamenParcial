class Usuario {
    private String dni;
    private String nombre;
    private String direccion;
    private Prestamo[] prestamos;
    private int contadorPrestamos;
    private static final int CAPACIDAD_MAXIMA = 50;
    
    public Usuario(String dni, String nombre, String direccion) {
        this.dni = dni;
        this.nombre = nombre;
        this.direccion = direccion;
        this.prestamos = new Prestamo[CAPACIDAD_MAXIMA];
        this.contadorPrestamos = 0;
    }
    
    public Usuario(String dni, String nombre) {
        this(dni, nombre, "Sin dirección");
    }
}

class Usuario {
    public String obtenerDni() {
        return dni;
    }
    
    public String obtenerNombre() {
        return nombre;
    }
    
    public String obtenerDireccion() {
        return direccion;
    }
}
class Usuario {
    public void agregarPrestamo(Prestamo prestamo) {
        if (contadorPrestamos < CAPACIDAD_MAXIMA) {
            prestamos[contadorPrestamos] = prestamo;
            contadorPrestamos++;
        }
    }
}

class Usuario {
    public Prestamo[] obtenerHistorialPrestamos() {
        Prestamo[] historial = new Prestamo[contadorPrestamos];
        for (int i = 0; i < contadorPrestamos; i++) {
            historial[i] = prestamos[i];
        }
        return historial;
    }
}
class Usuario {
    private Prestamo[] redimensionarArray(Prestamo[] original, int nuevoTamanio) {
        Prestamo[] resultado = new Prestamo[nuevoTamanio];
        for (int i = 0; i < nuevoTamanio; i++) {
            resultado[i] = original[i];
        }
        return resultado;
    }
}
class Usuario {
    public Prestamo[] obtenerPrestamosActivos() {
        Prestamo[] activos = new Prestamo[contadorPrestamos];
        int j = 0;
        for (int i = 0; i < contadorPrestamos; i++) {
            if (prestamos[i] != null && prestamos[i].estaActivo()) {
                activos[j] = prestamos[i];
                j++;
            }
        }
        return redimensionarArray(activos, j);
    }
}
class Usuario {
    private String obtenerFechaActual() {
        return "25/03/2025";
    }
}

class Usuario {
    public boolean tienePrestamosVencidos() {
        String fechaActual = obtenerFechaActual();
        for (int i = 0; i < contadorPrestamos; i++) {
            if (prestamos[i] != null && prestamos[i].estaActivo() && 
                prestamos[i].estaVencido(fechaActual)) {
                return true;
            }
        }
        return false;
    }
}
