class Libro{
    public Libro(String titulo, String autor, String codigo):
    public Libro(String titulo, String autor);

    public String obtenerTitulo();
    public String obtenerAutor();
    public String obtenerCodigo();
    public boolean estaPrestado();
    public void prestar();
    public void devolver();
    public String toString();
}

class Usuario {
    public Usuario(String dni, String nombre, String direccion);
    public Usuario(String dni, String nombre);

    public String obtenerDNi();
    public String obtenerNombre();
    public String obtenerDireccion();
    public void agregarPrestamo(Prestamo prestamo);
    public Prestamo[] obtenerPrestamosActivos();
    public Prestamo[] obtenerHistorialPrestamos();
    public boolean tienePrestamosVencidos();
    public String toString();
}

class Prestamo {
    public Prestamo(Libro libro, Usuario usuario, String fechaPrestamo);

    public Libro obtenerLibro();
    public Usuario obtenerUsuario();
    public String obtenerFechaPrestamo();
    public String obtenerFechaDevolucion();
    public void registrarDevolucion(String fechaDevolucion);
    public boolean estaVencido(String fechaActual);
    public int calcularDiasRetraso(String fechaActual);
    public boolean estaActivo();
    public String toString();
}

public class BibliotecaMunicipal{
    public static void main(String[] args) {
        Libro libro1 = new Libro("Don Quijote", "Cervantes", "B001");
        Libro libro2 = new Libro("Cien años de soledad", "García Márquez", "B002");

        Usuario usuario1 = new Usuario("12345678A", "Ana García", "Calle juncal 9");
        Usuario usuario2 = new Usuario("87654321B", "Juan Pérez", "Calle adela bazo 16");



        Prestamo prestamo1 = new Prestamo(libro1, usuario1, "01/03/2025");
        libro1.prestar();
        usuario1.agregarPrestamo(prestamo1);
        Prestamo prestamo2 = new Prestamo(libro2, usuario2, "10/03/2025");
        libro2.prestar();
        usuario2.agregarPrestamo(prestamo2);

        prestamo1.registrarDevolucion("15/03/2025");
        libro1.devolver();
    }
}